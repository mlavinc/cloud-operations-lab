# =============================================================================
# Terraform
# =============================================================================

# Downloaded provider plugins - ignore in any subdirectory
**/.terraform/

# All Terraform state files, including backups and numbered rotations
*.tfstate
*.tfstate.*

# terraform.tfvars is auto-loaded by Terraform and is per-developer.
# It may contain account-specific or sensitive values and is never committed.
terraform.tfvars

# *.auto.tfvars files are also auto-loaded and follow the same rule.
*.auto.tfvars

# Named var files (e.g. dev.tfvars, prod.tfvars) ARE committed.
# They contain environment configuration, are explicitly passed with
# -var-file=, and are required by CI. They must be in the repository.

# Binary plan output files - environment-specific and potentially sensitive
*.tfplan

# Crash log files generated by Terraform
crash.log
crash.*.log

# =============================================================================
# What IS committed (never ignored)
# =============================================================================
# .terraform.lock.hcl  - provider version lock file, always commit this
# *.tfvars.example     - documented variable templates
# **/*.tf              - all Terraform source files

# =============================================================================
# OS and editor artifacts
# =============================================================================

# macOS
.DS_Store

# Windows
Thumbs.db

# VSCode / Cursor
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
